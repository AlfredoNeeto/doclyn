# .NET gitignore

# Build outputs
bin/
obj/
out/

# Test results and coverage
TestResults/
coverage/
*.coverage
*.coveragexml

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains Rider
.idea/
*.sln.iml

# NuGet
*.nupkg
*.snupkg
project.lock.json
project.fragment.lock.json
artifacts/
packages/

# User secrets (development)
**/secrets.json
appsettings.*.local.json

# Publish output
publish/
**/publish/

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/
.env
