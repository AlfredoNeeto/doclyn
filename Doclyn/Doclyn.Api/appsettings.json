{
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=doclyn;Username=postgres;Password=changeme"
  },

  "Jwt": {
    "Issuer": "Doclyn",
    "Audience": "Doclyn",
    "Secret": "USE_USER_SECRETS_OR_ENVIRONMENT_VARIABLE",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },

  "Smtp": {
    "Host": "smtp.hostinger.com",
    "Port": 587,
    "Username": "",
    "Password": "",
    "From": "contato@doclyn.com.br",
    "EnableSsl": true
  },

  "Storage": {
    "Provider": "Minio",
    "BucketName": "doclyn-documents",
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "UseSsl": false
  },

  "Classification": {
    "ReuseThreshold": 0.85
  },

  "FieldConfidence": {
    "ValidatedThreshold": 0.90,
    "ReviewThreshold": 0.70,
    "DefaultAiConfidence": 0.80
  },

  "Insights": {
    "Enabled": true,
    "ContractExpiringSoonDays": 30,
    "LowConfidenceThreshold": 0.70,
    "HighValueThreshold": 50000,
    "EnableAiInsights": true
  },

  "Documents": {
    "MaxUploadSizeInMb": 10
  },

  "Ocr": {
    "Enabled": true,
    "Language": "por",
    "TessDataPath": "./tessdata",
    "MinimumTextLength": 100,
    "MaxPages": 20,
    "Dpi": 300
  },

  "OpenAi": {
    "Model": "gpt-5.4",
    "ApiKey": "",
    "Temperature": 0.1,
    "MaxTokens": 4000
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ]
  }
}
